# Core app settings (Pydantic Settings uses PS_ prefix)
PS_APP_NAME=prospect-shortlisting-scraper

# Database
# SQLite (local dev):
PS_DATABASE_URL=sqlite:///data/scrape_service.db
# PostgreSQL (production):
# PS_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME

# Models
PS_GENERAL_MODEL=mistralai/mistral-small-2603
PS_CLASSIFY_MODEL=mistralai/mistral-small-2603

# LLM provider (OpenRouter)
PS_OPENROUTER_API_KEY=your_openrouter_api_key_here
PS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PS_OPENROUTER_SITE_URL=https://local.prospect-shortlisting
PS_OPENROUTER_APP_NAME=prospect-shortlisting-scraper

# Redis (Celery broker)
# Local:
PS_REDIS_URL=redis://127.0.0.1:6379/0
# With password:
# PS_REDIS_URL=redis://:YOUR_PASSWORD@HOST:PORT/0

# Scrape performance tuning
PS_SCRAPE_STATIC_TIMEOUT_SEC=12
PS_SCRAPE_STATIC_RETRIES=1
PS_SCRAPE_DYNAMIC_TIMEOUT_MS=28000
PS_SCRAPE_DYNAMIC_WAIT_MS=3000
PS_SCRAPE_DYNAMIC_RETRIES=1
PS_SCRAPE_STEALTH_TIMEOUT_MS=120000
# Optional: enable network fetch tests (`tests/test_fetch_live_domains.py`).
# PS_SCRAPE_LIVE_BENCHMARK=1
# Optional: full scrape pipeline integration (`tests/test_scrape_pipeline_integration.py`) — same code path as the UI/Celery worker.
# PS_SCRAPE_PIPELINE_E2E=1

# Local Scrapling browser fallback (used only after static and curl_cffi fetches fail)
PS_SCRAPE_STEALTH_MAX_PAGES=2
PS_SCRAPE_STEALTH_BLOCK_IMAGES=true
PS_SCRAPE_STEALTH_DISABLE_RESOURCES=true
PS_SCRAPE_STEALTH_HUMANIZE=true
PS_SCRAPE_STEALTH_OS_RANDOMIZE=true

# Optional proxy for stealth fetcher. Leave blank unless configured.
PS_SCRAPE_PROXY_URL=

# Misc
PS_UPLOAD_FILE_TTL_HOURS=24
PS_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Contact fetching (Snov.io)
PS_SNOV_CLIENT_ID=your_snov_client_id_here
PS_SNOV_CLIENT_SECRET=your_snov_client_secret_here
APOLLO_API_KEY=your_key

# Email verification (ZeroBounce) — optional, leave empty to skip verification
PS_ZEROBOUNCE_API_KEY=
