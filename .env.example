# Core app settings (Pydantic Settings uses PS_ prefix)
PS_APP_NAME=prospect-shortlisting-scraper
# Local dev (SQLite):
# PS_DATABASE_URL=sqlite:///data/scrape_service.db
# Cloud SQL Postgres (Cloud Run + Unix socket):
# PS_DATABASE_URL=postgresql+psycopg://DB_USER:DB_PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
PS_DATABASE_URL=sqlite:///data/scrape_service.db

# Models (optional overrides; defaults exist in code)
PS_GENERAL_MODEL=openai/gpt-5-nano
PS_CLASSIFY_MODEL=inception/mercury-2
PS_OCR_MODEL=google/gemini-3.1-flash-lite-preview
PS_MAX_IMAGES_PER_PAGE=8

# LLM provider keys
# REQUIRED for scrape link classification + markdown/OCR model calls
PS_OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional metadata for OpenRouter requests
PS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PS_OPENROUTER_SITE_URL=https://local.prospect-shortlisting
PS_OPENROUTER_APP_NAME=prospect-shortlisting-scraper

# Optional fallback if using OpenAI directly (when not using OpenRouter)
PS_OPENAI_API_KEY=

# Alternative unprefixed key (supported as fallback by services)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Queue / worker settings (MVP async processing)
# Non-TLS Redis URL (as requested). Example with password:
# PS_REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379/0
PS_REDIS_URL=redis://127.0.0.1:6379/0
PS_REDIS_QUEUE_KEY=prospect:jobs
PS_WORKER_BLOCK_TIMEOUT_SEC=5
PS_WORKER_CLEANUP_INTERVAL_SEC=900

# Transient upload file retention fallback (hours)
PS_UPLOAD_FILE_TTL_HOURS=24

# Frontend dev origins (comma-separated) for CORS.
PS_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
